pipeline {
    agent any

    stages {
        stage('Unit Tests - Backend') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21'
                    args '-u root'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-backend') {
                    sh '''
                        export GOCACHE=/tmp/go-cache
                        export GOMODCACHE=/tmp/go-mod-cache

                        mkdir -p $GOCACHE $GOMODCACHE

                        go test -v ./...
                    '''
                }
            }
        }
    }
}